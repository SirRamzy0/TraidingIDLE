  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 632f19e8c7ae1bd4a9280c02ab5055e5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TraidingIDLE.UI.MenuHelperTextByTab
  menu: {fileID: 1728360634}
  helperText: {fileID: 1421891914}
  helperCanvasGroup: {fileID: 0}
  messages:
  - tabName: "\u0422\u043E\u0440\u0433\u043E\u0432\u043B\u044F"
    text: "\u0414\u043E\u043A\u0443\u043F\u0430\u0439 \u043D\u0430 \u043F\u0430\u0434\u0435\u043D\u0438\u0438,
      \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u0439 \u043D\u0430 \u043F\u0438\u043A\u0435
      \u0440\u043E\u0441\u0442\u0430, \u043F\u043E\u043C\u043D\u0438 \u0447\u0442\u043E
      \u0442\u0440\u0435\u0439\u0434\u0438\u043D\u0433 \u044D\u0442\u043E \u0442\u0440\u0435\u0437\u0432\u044B\u0439
      \u0443\u043C \u0438 \u0442\u043E\u0447\u043D\u044B\u0439 \u0440\u0430\u0441\u0441\u0447\u0435\u0442"
    localizationKey: 
  - tabName: "\u041C\u0430\u0439\u043D\u0438\u043D\u0433"
    text: "\u041F\u043E\u043A\u0443\u043F\u0430\u0439 \u043D\u043E\u0432\u044B\u0435
      \u0440\u0438\u0433\u0438 \u0438 \u0443\u043B\u0443\u0447\u0448\u0430\u0439
      \u0432 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043A\u0440\u0443\u0442\u044B\u0435 \u0441\u0431\u043E\u0440\u043A\u0438! 
      \u041F\u043E\u043B\u0443\u0447\u0430\u0439 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u0439
      \u0434\u043E\u0445\u043E\u0434 \u0434\u0430\u0436\u0435 \u043A\u043E\u0433\u0434\u0430
      \u0442\u044B \u043E\u0444\u0444\u043B\u0430\u0439\u043D"
    localizationKey: 
  - tabName: "\u0411\u0438\u0437\u043D\u0435\u0441"
    text: "\u0411\u0438\u0437\u043D\u0435\u0441\u044B \u043E\u0447\u0435\u043D\u044C
      \u043F\u0440\u0438\u0431\u044B\u043B\u044C\u043D\u044B, \u043D\u043E \u0431\u044B\u0441\u0442\u0440\u043E
      \u0442\u0435\u0440\u044F\u044E\u0442 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
      \u043A\u043E\u0433\u0434\u0430 \u0442\u044B \u043E\u0444\u0444\u043B\u0430\u0439\u043D. 
      \u0422\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0448\u044C \u043F\u0440\u0438\u0431\u044B\u043B\u044C
      \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C \u0437\u0430 6\u0447 \u043E\u0444\u0444\u043B\u0430\u0439\u043D\u0430"
    localizationKey: 
  - tabName: "\u041A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u0438"
    text: "\u041F\u043E\u043A\u0430\u0436\u0438 \u0447\u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0433
      \u0438 \u043A\u0430\u043A\u0438\u0435 \u043F\u043E\u043A\u0443\u043F\u043A\u0438
      \u0442\u044B \u0443\u0436\u0435 \u043C\u043E\u0436\u0435\u0448\u044C \u0441\u0435\u0431\u0435
      \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442\u044C! \u041A\u0443\u043F\u0438
      \u0432\u0441\u044E \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044E \u0438
      \u043F\u043E\u043B\u0443\u0447\u0438 \u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0435
      \u0431\u043E\u043D\u0443\u0441\u044B"
    localizationKey: 
  - tabName: "\u0422\u0435\u043C\u043A\u0438"
    text: "\u0411\u044B\u0441\u0442\u0440\u044B\u0435 \u0434\u0435\u043D\u044C\u0433\u0438,
      \u043D\u043E \u0432\u044B\u0441\u043E\u043A\u0438\u0439 \u0440\u0438\u0441\u043A. 
      \u0423\u0433\u0430\u0434\u0430\u0439 \u043A\u0443\u0434\u0430 \u043F\u043E\u0439\u0434\u0435\u0442
      \u0433\u0440\u0430\u0444\u0438\u043A \u0438 \u0443\u043C\u043D\u043E\u0436\u044C
      \u0441\u0432\u043E\u044E \u0441\u0442\u0430\u0432\u043A\u0443 \u043D\u0430
      \u04455 \u044510 \u0438\u043B\u0438 \u0434\u0430\u0436\u0435 \u044520 "
    localizationKey: 
  fallbackText: 
  clearTextIfMessageMissing: 0
  animateTextChange: 1
  fadeOutSeconds: 0.08
  fadeInSeconds: 0.12
  useUnscaledTime: 1
